# Copy this file to config/default.toml and customise for your setup.
# Run `aigent onboard` to have the wizard fill it in interactively.

[agent]
name = "Aigent"
user_name = ""
workspace_path = "./workspace"
thinking_level = "balanced"

# Externalized reasoning mode.  When true, the agent outputs short JSON
# steps instead of long internal monologues.  Best for large local models
# (e.g. Qwen 3.5 35B MoE via Ollama) that tend to timeout during long
# unstructured reasoning.
# Toggle at runtime: /thinking external  or  /thinking model
external_thinking = false
# Per-step timeout in seconds (only in external thinking mode).
step_timeout_seconds = 12
# Maximum reasoning steps per turn.
max_steps_per_turn = 10

[llm]
provider = "ollama"
ollama_model = "llama3.1:8b"
openrouter_model = "openai/gpt-4o-mini"
ollama_local_first = true
ollama_base_url = "http://localhost:11434"

[memory]
backend = "eventlog"
auto_sleep_minutes = 120
auto_sleep_turn_interval = 6
auto_sleep_mode = "nightly"
night_sleep_start_hour = 22
night_sleep_end_hour = 6
core_rewrite_requires_approval = true
multi_agent_sleep_batch_size = 60
# Maximum entries per tier in the YAML vault KV summaries (core, user-profile, reflective).
kv_tier_limit = 15
# IANA timezone for the nightly sleep window. Examples: "America/New_York", "Europe/Berlin".
timezone = "UTC"
# Remove low-confidence Episodic entries older than N days during the sleep cycle.
# Set to 0 to disable lightweight forgetting.
forget_episodic_after_days = 0
forget_min_confidence = 0.30

# Proactive mode: set proactive_interval_minutes > 0 to enable.
# The daemon will periodically check whether it has something worth proactively
# sharing with the user (a follow-up, reminder, or insight).
proactive_interval_minutes = 0
# Do-not-disturb window in local time.  Proactive messages are suppressed
# between dnd_start and dnd_end (inclusive of both sides of midnight wrap).
proactive_dnd_start_hour = 22
proactive_dnd_end_hour = 8
# Minimum gap (minutes) between sent proactive messages.
# Prevents bursts even when the check interval is short.
proactive_cooldown_minutes = 5
# Maximum number of current beliefs injected into each conversation prompt.
# Beliefs are sorted by composite score (confidence × recency × valence) before truncation.
# 0 = unlimited (use with care on long-running agents).
max_beliefs_in_prompt = 5
# Maximum relational matrix entries per bucket (USER, MY_BELIEFS, OUR_DYNAMIC).
# Entries are deduplicated by content and sorted most-recent-first.
# Without this cap, long-running agents can accumulate thousands of
# UserProfile/Reflective entries, inflating the prompt to 300K+ chars.
# 0 = unlimited (NOT recommended in production).
max_relational_in_prompt = 20
# Hard ceiling on the total system prompt in characters.
# When exceeded, the builder truncates the largest expandable sections
# (relational → conversation → memory context) until the prompt fits.
# ~48K chars ≈ 12K tokens, leaving room for the model’s response in a
# 32K context window.  Set to 0 to disable the guard.
max_prompt_chars = 48000

[safety]
approval_required = true
allow_shell = false
allow_wasm = false
# Per-tool allow-list (empty = all tools are permitted subject to capability gates).
# Supports @group syntax:  ["@filesystem", "web_search"]
tool_allowlist = []
# Per-tool deny-list (takes precedence over tool_allowlist).
# Supports @group syntax:  ["@shell"] blocks all tools in the "shell" group.
tool_denylist = []
# Tools that bypass interactive approval even when approval_required = true.
# The four safe built-in tools are exempt by default.
approval_exempt_tools = ["calendar_add_event", "remind_me", "draft_email", "web_search", "browse_page"]
# Maximum number of times any single tool may be called per session.
# 0 = unlimited.  Default: 25.
# max_calls_per_tool = 25
# Maximum security level allowed for any tool.  Tools above this level are
# blocked outright.  Values: "low", "medium", "high".  Default: "high".
max_security_level = "high"

# ── Per-tool policy overrides ────────────────────────────────────────────────
# Fine-grained control over individual tools.  Example:
# [safety.tool_overrides.run_shell]
# denied = false                    # set true to block this tool entirely
# approval_mode = "safer"           # override global approval mode
# max_security_level = "medium"     # per-tool security ceiling

# ── Tool trust & action config ───────────────────────────────────────────────
[tools]
# How aggressively the agent asks for permission before running tools.
#
#   safer      — every tool requires interactive approval (great for first-time
#                use or when the workspace contains sensitive files)
#   balanced   — read-only tools (read_file, web_search, remind_me,
#                calendar_add_event, git_rollback) run freely; write_file,
#                run_shell, and draft_email require approval  ← DEFAULT
#   autonomous — no approval prompts (still workspace-sandboxed and deny-listed)
#
# The legacy [safety] approval_required flag is ignored when this is not "safer".
approval_mode = "balanced"

# Brave Search API key.  When non-empty the web_search tool uses the Brave
# Search REST API instead of DuckDuckGo Instant Answers.
# RECOMMENDED: set via the BRAVE_API_KEY environment variable (or .env file)
# instead of here.  Env vars always take precedence over this file.
# Get a free key at https://api.search.brave.com/app/
brave_api_key = ""

# Automatically git-commit workspace changes after every successful write_file
# or run_shell tool call.  Requires git to be installed.
# (The workspace will be git-init'd automatically during onboarding if this is true.)
git_auto_commit = false

# Apply platform-level process sandboxing to `run_shell` children.
# Requires the binary to have been compiled with the `sandbox` feature (default).
# Set to false to disable sandboxing at runtime without recompiling.
sandbox_enabled = true

# Maximum number of LLM↔tool round-trips per user turn before the agent stops
# and returns whatever it has.  Prevents runaway loops.
max_tool_rounds = 5

# ── Search provider configuration ────────────────────────────────────────────
# Tavily Search API key. Provides AI-generated answers alongside results.
# RECOMMENDED: set via TAVILY_API_KEY env var.  Get a free key at https://tavily.com
tavily_api_key = ""

# SearXNG base URL. Self-hosted meta-search engine.
# RECOMMENDED: set via SEARXNG_BASE_URL env var.
# Example: "http://localhost:8080"
searxng_base_url = ""

# Serper (Google Search) API key.  Uses the Google Search API via serper.dev.
# RECOMMENDED: set via SERPER_API_KEY env var.  Get a key at https://serper.dev
serper_api_key = ""

# Exa.ai API key for semantic/neural web search.
# RECOMMENDED: set via EXA_API_KEY env var.  Get a key at https://exa.ai
exa_api_key = ""

# Ordered list of search providers to try.  The agent tries each in order and
# returns results from the first that succeeds.
# Available: "brave", "tavily", "serper", "exa", "searxng", "duckduckgo"
search_providers = ["brave", "tavily", "serper", "exa", "searxng", "duckduckgo"]


# ── Skills (WASM tool plugins) ───────────────────────────────────────────────
[tools.skills]
enabled = true
skills_dir = "extensions/skills"
auto_reload = true
max_skills = 64

[telemetry]
log_level = "info"

[onboarding]
completed = false

[integrations]
telegram_enabled = false

[daemon]
socket_path = "/tmp/aigent.sock"

# ── UI ──────────────────────────────────────────────────────────────────────
[ui]
theme = "catppuccin-mocha"
show_sidebar = true

# ── Git integration (gait) ──────────────────────────────────────────────────────────
[git]
# Repository URLs considered trusted for push / commit identity.
trusted_repos = ["https://github.com/danielmriley/aigent"]
# Absolute paths where git write ops are allowed.
# workspace_path and the Aigent source dir are always auto-added at runtime.
trusted_write_paths = []
# Allow read-only git ops (status, log, diff, blame, ls-remote) on any repo.
# Set to false in "safer" mode to restrict reads to trusted_write_paths only.
allow_system_read = true

# ── Local inference (Candle) ──────────────────────────────────────────────────
# Requires building with:  ./install.sh --candle
# Or manually:             cargo build --release -p aigent-app --features candle
[inference]
# Enable the Candle local-inference backend. When true, the agent loads a GGUF
# model from HuggingFace Hub (or a local path) and runs inference in-process.
# Requires the binary to have been compiled with the `candle` feature.
candle_enabled = false

# HuggingFace Hub repository containing the GGUF model file.
candle_model_repo = "Qwen/Qwen2.5-Coder-1.5B-Instruct-GGUF"
# GGUF filename within the repository.
candle_model_file = "qwen2.5-coder-1.5b-instruct-q4_k_m.gguf"

# Absolute path to a local GGUF file. Overrides repo/file if non-empty.
candle_model_path = ""
# Directory to store downloaded model files.
candle_local_models_dir = "~/.cache/aigent/models"

# Maximum sequence length (context window). Higher values use more VRAM/RAM.
candle_max_seq_len = 4096
# Sampling: temperature (0.0 = greedy), top-p (nucleus), repeat penalty.
candle_temperature = 0.7
candle_top_p = 0.9
candle_repeat_penalty = 1.1

# Compute device:  "cpu", "cuda" (NVIDIA), or "metal" (Apple Silicon).
candle_device = "cpu"

# ── Small-model router ──────────────────────────────────────────────────────
# When enabled, a tiny model (0.5B–3B) classifies each message as CHAT or
# TOOLS before dispatching.  CHAT messages are answered directly by the
# router model, bypassing the full thinker loop for lightning-fast replies.
# Disable (the default) to always use the primary model.
#
# VRAM NOTE: By default the router reuses the primary model for both
# classification and chat responses.  This avoids VRAM model-swapping on
# single-GPU setups (each swap costs ~10-15 s).  The speed benefit comes
# from skipping the tool loop, external-thinking JSON parsing, and the
# reflection step — not from using a smaller model.
#
# If you have a multi-GPU rig or enough VRAM to keep two models loaded
# concurrently (set OLLAMA_MAX_LOADED_MODELS=2), you can set ollama_model
# to a small model like "qwen3.5:0.8b" for even faster classification and
# responses.
[router]
enabled = false

# Which provider the router model lives on: "ollama" or "openrouter".
provider = "ollama"

# Model to use for classification and fast-path chat.
# When empty (the default), the router reuses the primary model from [llm]
# — zero VRAM overhead.  Set to a specific model only if your GPU can
# keep both loaded simultaneously.
ollama_model = ""
openrouter_model = ""

# Timeout for the classification call (seconds).  Falls back to TOOLS on timeout.
classify_timeout_seconds = 8
# Timeout for the router model's chat response (seconds).
chat_timeout_seconds = 45

# Classification system prompt.  Uncomment to override the built-in default.
# classify_system_prompt = "..."

# ── Debug and observability ──────────────────────────────────────────────────

# ── Parallel subagent reasoning ─────────────────────────────────────────────
# When enabled, complex queries are evaluated by multiple specialist agents
# (Researcher, Planner, Critic) running in parallel before the main agent
# responds.  Requires OLLAMA_NUM_PARALLEL >= 3 on the Ollama server.
[subagents]
enabled = false

# Specialist system prompts (uncomment to override the built-in defaults).
# researcher_prompt = "You are a meticulous researcher..."
# planner_prompt = "You are a strategic planner..."
# critic_prompt = "You are a rigorous critic..."

# ── Debug and observability ──────────────────────────────────────────────────
# Runtime debugging settings.  All options default to production-safe values.
# Change them here or at runtime via hot-reload without recompiling.
[debug]
# Master log level for the tracing subscriber.
# Accepted values: "error", "warn", "info", "debug", "trace".
# RUST_LOG env var always takes precedence if set.
log_level = "info"

# Write a copy of log output to .aigent/runtime/debug.log.
# The file is truncated on each daemon restart.
log_to_file = true

# Log full details for each router classify call: the system prompt sent,
# the raw model response, and per-phase timing.  Useful when diagnosing
# why the router picks TOOLS vs CHAT.
verbose_routing = false

# Log per-turn timing breakdowns: prompt build, router classify, LLM
# response, memory writes, reflection, and total wall-clock time.
timing = true